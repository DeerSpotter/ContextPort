+    private var trimmedName: String {
+        memoryName.trimmingCharacters(in: .whitespacesAndNewlines)
+    }
+
+    var body: some View {
+        NavigationStack {
+            Form {
+                Section("Memory Name") {
+                    TextField("Memory name", text: $memoryName)
+                        .textInputAutocapitalization(.sentences)
